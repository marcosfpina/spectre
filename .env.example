# SPECTRE Fleet Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# Database
POSTGRES_USER=spectre
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=spectre_observability

# Neo4j
NEO4J_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# JWT (used by spectre-proxy)
JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET

# NATS
NATS_URL=nats://localhost:4222

# Proxy
NEUTRON_URL=http://localhost:8000
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# TLS (optional, enable for production)
TLS_ENABLED=false
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER_ARG=0.1
RUST_LOG=info
SPECTRE_LOG_FORMAT=pretty
SPECTRE_ENV=dev
